        <mxCell id="GTmY1kIJbH37y-SKA163-3" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-section-id=&quot;jtqqt0&quot; data-start=&quot;357&quot; data-end=&quot;392&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;362&quot; data-end=&quot;392&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;A. Functional Requirements&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h1&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;ol data-start=&quot;394&quot; data-end=&quot;912&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;8tn1yp&quot; data-start=&quot;394&quot; data-end=&quot;460&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Users should be able to register, login, and manage profiles.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1d97tp8&quot; data-start=&quot;461&quot; data-end=&quot;532&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Users should be able to browse movies, theaters, and show timings.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;168k1k6&quot; data-start=&quot;533&quot; data-end=&quot;592&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Users should be able to select seats and book tickets.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;umhszk&quot; data-start=&quot;593&quot; data-end=&quot;656&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;System should support real-time seat availability updates.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;ew6r40&quot; data-start=&quot;657&quot; data-end=&quot;733&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Users should be able to make payments and receive booking confirmation.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1vtygry&quot; data-start=&quot;734&quot; data-end=&quot;796&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Users should be able to cancel tickets (based on policy).&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;19kkc1v&quot; data-start=&quot;797&quot; data-end=&quot;849&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Users should receive notifications (email/SMS).&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;d4106s&quot; data-start=&quot;850&quot; data-end=&quot;912&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Admin should be able to manage movies, shows, and theaters.&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="470" width="1110" x="165" y="260" as="geometry" />
        </mxCell>
        <mxCell id="GTmY1kIJbH37y-SKA163-4" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-section-id=&quot;98m4wt&quot; data-start=&quot;919&quot; data-end=&quot;958&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;924&quot; data-end=&quot;958&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;B. Non-Functional Requirements&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h1&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;ol data-start=&quot;960&quot; data-end=&quot;1403&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1ud6y62&quot; data-start=&quot;960&quot; data-end=&quot;1033&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;strong data-start=&quot;963&quot; data-end=&quot;973&quot;&gt;Scale:&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;979&quot; data-end=&quot;1033&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1mbvqx1&quot; data-start=&quot;979&quot; data-end=&quot;991&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;1–2M DAU&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;v222ef&quot; data-start=&quot;995&quot; data-end=&quot;1033&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Peak load during weekends/releases&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/ul&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1vbgkj0&quot; data-start=&quot;1035&quot; data-end=&quot;1162&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;strong data-start=&quot;1038&quot; data-end=&quot;1054&quot;&gt;CAP Theorem:&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1060&quot; data-end=&quot;1162&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;xkav2h&quot; data-start=&quot;1060&quot; data-end=&quot;1090&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Availability &amp;gt; Consistency&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;10jlhy0&quot; data-start=&quot;1094&quot; data-end=&quot;1162&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;(Temporary seat inconsistency acceptable but avoid double booking)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/ul&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1ejaa2w&quot; data-start=&quot;1164&quot; data-end=&quot;1247&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;strong data-start=&quot;1167&quot; data-end=&quot;1179&quot;&gt;Latency:&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1185&quot; data-end=&quot;1247&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1quh95n&quot; data-start=&quot;1185&quot; data-end=&quot;1211&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Seat selection &amp;lt; 200ms&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;13paml5&quot; data-start=&quot;1215&quot; data-end=&quot;1247&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Booking confirmation &amp;lt; 500ms&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/ul&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1lrag90&quot; data-start=&quot;1249&quot; data-end=&quot;1338&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;strong data-start=&quot;1252&quot; data-end=&quot;1272&quot;&gt;Fault Tolerance:&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1278&quot; data-end=&quot;1338&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;12xnpft&quot; data-start=&quot;1278&quot; data-end=&quot;1304&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Retry payment failures&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;xy3znv&quot; data-start=&quot;1308&quot; data-end=&quot;1338&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Prevent duplicate bookings&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/ul&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1922g96&quot; data-start=&quot;1340&quot; data-end=&quot;1403&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;strong data-start=&quot;1343&quot; data-end=&quot;1365&quot;&gt;High Availability:&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1371&quot; data-end=&quot;1403&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1cj8bcu&quot; data-start=&quot;1371&quot; data-end=&quot;1403&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Load balancers + replication&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/ul&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="1030" width="1280" x="170" y="970" as="geometry" />
