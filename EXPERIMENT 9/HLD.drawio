        <mxCell id="GTmY1kIJbH37y-SKA163-5" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-section-id=&quot;ncq2d6&quot; data-start=&quot;1410&quot; data-end=&quot;1435&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;1415&quot; data-end=&quot;1435&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;C. Core Entities&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h1&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;ol data-start=&quot;1437&quot; data-end=&quot;1555&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;2m7c3c&quot; data-start=&quot;1437&quot; data-end=&quot;1447&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Users&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1j4rfjm&quot; data-start=&quot;1448&quot; data-end=&quot;1459&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Movies&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;lhlkls&quot; data-start=&quot;1460&quot; data-end=&quot;1473&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Theaters&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1pr968w&quot; data-start=&quot;1474&quot; data-end=&quot;1486&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Screens&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;xm7ecu&quot; data-start=&quot;1487&quot; data-end=&quot;1497&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Shows&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1dno9e5&quot; data-start=&quot;1498&quot; data-end=&quot;1508&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Seats&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1c17xs6&quot; data-start=&quot;1509&quot; data-end=&quot;1522&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Bookings&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1l0eh6i&quot; data-start=&quot;1523&quot; data-end=&quot;1536&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Payments&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;li data-section-id=&quot;1uvdzqk&quot; data-start=&quot;1537&quot; data-end=&quot;1555&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;Notifications&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/ol&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;h1 data-section-id=&quot;1omexuw&quot; data-start=&quot;1562&quot; data-end=&quot;1596&quot;&gt;&lt;/h1&gt;" vertex="1">
          <mxGeometry height="560" width="1005" x="175" y="2150" as="geometry" />
        </mxCell>
        <mxCell id="GTmY1kIJbH37y-SKA163-6" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h3 data-path-to-node=&quot;12&quot;&gt;D. API-Design&lt;/h3&gt;&lt;p data-path-to-node=&quot;13&quot;&gt;&lt;b data-path-to-node=&quot;13&quot; data-index-in-node=&quot;0&quot;&gt;Users:&lt;/b&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;14&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,0,0&quot;&gt;&lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;0&quot;&gt;POST: /auth/signup&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,1,0&quot;&gt;&lt;code data-path-to-node=&quot;14,1,0&quot; data-index-in-node=&quot;0&quot;&gt;POST: /auth/login&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;14,2,0&quot;&gt;&lt;code data-path-to-node=&quot;14,2,0&quot; data-index-in-node=&quot;0&quot;&gt;GET: /api/v1/users/profile&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p data-path-to-node=&quot;15&quot;&gt;&lt;b data-path-to-node=&quot;15&quot; data-index-in-node=&quot;0&quot;&gt;Catalog &amp;amp; Search (High Read Volume):&lt;/b&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;16&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;16,0,0&quot;&gt;&lt;code data-path-to-node=&quot;16,0,0&quot; data-index-in-node=&quot;0&quot;&gt;GET: /api/v1/movies?city={city_id}&lt;/code&gt;  [Lists movies in a specific city]&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;16,1,0&quot;&gt;&lt;code data-path-to-node=&quot;16,1,0&quot; data-index-in-node=&quot;0&quot;&gt;GET: /api/v1/movies/{movie_id}&lt;/code&gt; [Movie details, cast, reviews]&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;16,2,0&quot;&gt;&lt;code data-path-to-node=&quot;16,2,0&quot; data-index-in-node=&quot;0&quot;&gt;GET: /api/v1/movies/{movie_id}/theaters?city={city_id}&lt;/code&gt; [Theaters playing the movie]&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;16,3,0&quot;&gt;&lt;code data-path-to-node=&quot;16,3,0&quot; data-index-in-node=&quot;0&quot;&gt;GET: /api/v1/shows/{show_id}/seats&lt;/code&gt; [Returns seat map and current availability]&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p data-path-to-node=&quot;17&quot;&gt;&lt;b data-path-to-node=&quot;17&quot; data-index-in-node=&quot;0&quot;&gt;Booking (High Consistency Volume):&lt;/b&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;18&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;18,0,0&quot;&gt;&lt;code data-path-to-node=&quot;18,0,0&quot; data-index-in-node=&quot;0&quot;&gt;POST: /api/v1/bookings/lock&lt;/code&gt; [Payload: show_id, seat_ids. Temporarily locks seats in Redis]&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;18,1,0&quot;&gt;&lt;code data-path-to-node=&quot;18,1,0&quot; data-index-in-node=&quot;0&quot;&gt;POST: /api/v1/bookings/confirm&lt;/code&gt; [Finalizes booking and writes to DB after payment]&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;18,2,0&quot;&gt;&lt;code data-path-to-node=&quot;18,2,0&quot; data-index-in-node=&quot;0&quot;&gt;GET: /api/v1/bookings/{booking_id}&lt;/code&gt; [Returns digital ticket info]&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p data-path-to-node=&quot;19&quot;&gt;&lt;b data-path-to-node=&quot;19&quot; data-index-in-node=&quot;0&quot;&gt;Payments:&lt;/b&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;20&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;20,0,0&quot;&gt;&lt;code data-path-to-node=&quot;20,0,0&quot; data-index-in-node=&quot;0&quot;&gt;POST: /api/v1/payments/process&lt;/code&gt; [Integrates with 3rd party like Stripe/Razorpay]&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="450" width="725" x="175" y="2860" as="geometry" />
        </mxCell>
