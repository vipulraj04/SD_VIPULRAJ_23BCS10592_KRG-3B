        <mxCell id="tFRkYtwEf9hMFKpUH4rO-15" value="(Eventual Consistency)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
