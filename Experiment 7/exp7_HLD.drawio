        <mxCell id="tFRkYtwEf9hMFKpUH4rO-13" value="(Strong Consistency)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="170" y="860" width="140" height="30" as="geometry" />
