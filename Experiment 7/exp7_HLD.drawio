        <mxCell id="tFRkYtwEf9hMFKpUH4rO-16" value="Within &amp;lt;1 min, the driver should get assigned" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
