        <mxCell id="Gt8_jnnvZfQtYwlD27bA-10" value="1. Target Scale: 1.5 Million : for both users &amp;amp; drivers" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-245" y="730" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="Gt8_jnnvZfQtYwlD27bA-11" value="2. CAP Theorem:&amp;nbsp;&lt;br&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-245" y="785" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="Gt8_jnnvZfQtYwlD27bA-12" value="3. Latency:" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-235" y="910" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="Gt8_jnnvZfQtYwlD27bA-15" value="Core-Entities" style="whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-240" y="1090" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="hc9dTFhTOF2EBiG-5zuw-1" value="API Endpoints" style="whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="-240" y="1450" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-1" value="It is an online platform, where users will be able to request for a ride booking." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-250" y="20" width="430" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-2" value="1. Rider / User Should be able to get a fare estimation based on the start location &amp;amp; destination" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-240" y="300" width="530" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-3" value="2. Riders should be able to request for a ride based on the estimated fare." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-240" y="340" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-4" value="3. Riders should be able to different categories of rides (by car, by bike etc)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-235" y="380" width="420" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-5" value="4. Drivers should be able to accept / decline a request and navigate to pickup / drop-off." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-240" y="420" width="490" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-6" value="5. Upon a request, riders should be matched with a driver who is nearby and available." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-235" y="460" width="480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-7" value="6. System should be able to get the real-time tracking of the driver and rider/user." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-235" y="500" width="450" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-8" value="7. Drivers &amp;amp; riders should be able to rate their ride past-trip." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-235" y="540" width="340" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-9" value="8. Riders should be able to make the payments." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-235" y="580" width="280" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-10" value="User Aspect:&amp;nbsp;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-205" y="820" width="90" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-11" value="Driver Aspect:&amp;nbsp;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-205" y="860" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tFRkYtwEf9hMFKpUH4rO-12" value="A single driver should not be assigned to multiple users." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-125" y="860" width="320" height="30" as="geometry" />
