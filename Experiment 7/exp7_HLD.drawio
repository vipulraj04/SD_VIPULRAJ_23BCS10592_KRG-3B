        <mxCell id="tFRkYtwEf9hMFKpUH4rO-14" value="High Availability for end-users." style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="-130" y="820" width="180" height="30" as="geometry" />
