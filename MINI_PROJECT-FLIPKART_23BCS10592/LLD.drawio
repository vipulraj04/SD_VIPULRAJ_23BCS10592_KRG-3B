          <mxGeometry height="830" width="1117.77" x="579.58" y="1720" as="geometry" />
        </mxCell>
        <mxCell id="whgB40gIaEY-8k9Yr9Ib-8" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h3 data-path-to-node=&quot;16&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;5. Design Patterns Used&lt;/font&gt;&lt;/h3&gt;&lt;ul data-path-to-node=&quot;17&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;17,0,0&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;b data-path-to-node=&quot;17,0,0&quot; data-index-in-node=&quot;0&quot;&gt;Singleton Pattern:&lt;/b&gt; Used for the &lt;code data-path-to-node=&quot;17,0,0&quot; data-index-in-node=&quot;32&quot;&gt;DatabaseConnection&lt;/code&gt; and &lt;code data-path-to-node=&quot;17,0,0&quot; data-index-in-node=&quot;55&quot;&gt;ConfigurationManager&lt;/code&gt; to ensure only one instance exists throughout the application lifecycle.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;17,1,0&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;b data-path-to-node=&quot;17,1,0&quot; data-index-in-node=&quot;0&quot;&gt;Factory Pattern:&lt;/b&gt; Used in &lt;code data-path-to-node=&quot;17,1,0&quot; data-index-in-node=&quot;25&quot;&gt;PaymentFactory&lt;/code&gt;. Based on the user&#39;s choice (e.g., &quot;UPI&quot;), the factory returns the appropriate payment object.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;17,2,0&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;b data-path-to-node=&quot;17,2,0&quot; data-index-in-node=&quot;0&quot;&gt;Strategy Pattern:&lt;/b&gt; Used for &lt;code data-path-to-node=&quot;17,2,0&quot; data-index-in-node=&quot;27&quot;&gt;PricingStrategy&lt;/code&gt; (to handle discounts/seasonal sales) and &lt;code data-path-to-node=&quot;17,2,0&quot; data-index-in-node=&quot;84&quot;&gt;PaymentStrategy&lt;/code&gt;.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;17,3,0&quot;&gt;&lt;font size=&quot;3&quot;&gt;&lt;b data-path-to-node=&quot;17,3,0&quot; data-index-in-node=&quot;0&quot;&gt;Observer Pattern:&lt;/b&gt; Used to notify the &lt;code data-path-to-node=&quot;17,3,0&quot; data-index-in-node=&quot;37&quot;&gt;InventorySystem&lt;/code&gt; and the &lt;code data-path-to-node=&quot;17,3,0&quot; data-index-in-node=&quot;61&quot;&gt;EmailService&lt;/code&gt; once an &lt;code data-path-to-node=&quot;17,3,0&quot; data-index-in-node=&quot;82&quot;&gt;Order&lt;/code&gt; status changes to &quot;Paid&quot;.&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="220" width="580" x="590" y="4570" as="geometry" />
        </mxCell>
        <mxCell id="KpuK1pq2YqOiBVYZuBWj-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h4 data-path-to-node=&quot;13&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; color: rgb(255, 255, 255); font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(27, 29, 30); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; font-family: &amp;quot;Google Sans&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;3. Relationships &amp;amp; Indexing:&lt;/h4&gt;&lt;ul data-path-to-node=&quot;14&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; color: rgb(255, 255, 255); font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(27, 29, 30); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; padding-inline-start: 32px; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;14,0,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;One-to-Many:&lt;/b&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;13&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Users&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;→&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;21&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Orders&lt;/code&gt;;&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;29&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Orders&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;→&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,0,0&quot; data-index-in-node=&quot;38&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Order_Items&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;14,1,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;14,1,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Indexing:&lt;/b&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;*&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,1,0&quot; data-index-in-node=&quot;12&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;idx_product_id&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;on&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,1,0&quot; data-index-in-node=&quot;30&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Inventory&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;for fast stock checks.&lt;/p&gt;&lt;ul data-path-to-node=&quot;14,1,1&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; padding-inline-start: 32px; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;14,1,1,0,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;code data-path-to-node=&quot;14,1,1,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;idx_user_id&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;on&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,1,1,0,0&quot; data-index-in-node=&quot;15&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Orders&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;to fetch order history quickly.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;14,1,1,1,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;14,1,1,1,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Composite Index:&lt;/b&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,1,1,1,0&quot; data-index-in-node=&quot;17&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;(order_id, product_id)&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;on&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;14,1,1,1,0&quot; data-index-in-node=&quot;43&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Order_Items&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="160" width="410" x="579.58" y="2710" as="geometry" />
        </mxCell>
        <mxCell id="KpuK1pq2YqOiBVYZuBWj-2" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h3 data-path-to-node=&quot;19&quot;&gt;4. Sequence Diagrams&lt;/h3&gt;&lt;p data-path-to-node=&quot;20&quot;&gt;These diagrams illustrate how components interact to complete a specific task.&lt;/p&gt;&lt;p data-path-to-node=&quot;20&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;h4 data-path-to-node=&quot;21&quot;&gt;Flow A: Placing an Order (Checkout)&lt;/h4&gt;&lt;p data-path-to-node=&quot;22&quot;&gt;This flow ensures stock is available before confirming the transaction.&lt;/p&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;23&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;23,0,0&quot;&gt;&lt;b data-path-to-node=&quot;23,0,0&quot; data-index-in-node=&quot;0&quot;&gt;User&lt;/b&gt; clicks &quot;Place Order&quot;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;23,1,0&quot;&gt;&lt;b data-path-to-node=&quot;23,1,0&quot; data-index-in-node=&quot;0&quot;&gt;OrderService&lt;/b&gt; calls &lt;b data-path-to-node=&quot;23,1,0&quot; data-index-in-node=&quot;19&quot;&gt;InventoryService&lt;/b&gt; to check availability.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;23,2,0&quot;&gt;&lt;b data-path-to-node=&quot;23,2,0&quot; data-index-in-node=&quot;0&quot;&gt;InventoryService&lt;/b&gt; &quot;locks&quot; the items (Optimistic Locking).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;23,3,0&quot;&gt;&lt;b data-path-to-node=&quot;23,3,0&quot; data-index-in-node=&quot;0&quot;&gt;PaymentService&lt;/b&gt; processes the transaction.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;23,4,0&quot;&gt;On success, &lt;b data-path-to-node=&quot;23,4,0&quot; data-index-in-node=&quot;12&quot;&gt;OrderService&lt;/b&gt; updates status to &lt;code data-path-to-node=&quot;23,4,0&quot; data-index-in-node=&quot;43&quot;&gt;PLACED&lt;/code&gt; and triggers &lt;b data-path-to-node=&quot;23,4,0&quot; data-index-in-node=&quot;63&quot;&gt;NotificationService&lt;/b&gt;.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;h4 data-path-to-node=&quot;24&quot;&gt;&lt;br&gt;&lt;/h4&gt;" vertex="1">
          <mxGeometry height="430" width="560" x="579.58" y="2910" as="geometry" />
        </mxCell>
        <mxCell id="KpuK1pq2YqOiBVYZuBWj-3" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="550" width="725.51" x="830" y="3230" as="geometry" />
        </mxCell>
        <mxCell id="KpuK1pq2YqOiBVYZuBWj-4" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h4 data-path-to-node=&quot;24&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; color: rgb(255, 255, 255); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(27, 29, 30); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;Flow B: Inventory Restocking&lt;/h4&gt;&lt;ol start=&quot;1&quot; data-path-to-node=&quot;25&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important; color: rgb(255, 255, 255); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(27, 29, 30); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;p data-path-to-node=&quot;25,0,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;b data-path-to-node=&quot;25,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;Admin/System&lt;/b&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;triggers a restock event.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;p data-path-to-node=&quot;25,1,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;b data-path-to-node=&quot;25,1,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;InventoryManager&lt;/b&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;validates the product ID.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;p data-path-to-node=&quot;25,2,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;b data-path-to-node=&quot;25,2,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;Database&lt;/b&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;updates the&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;25,2,0&quot; data-index-in-node=&quot;21&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;quantity&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;in the&lt;span&gt;&amp;nbsp;&lt;/span&gt;&lt;code data-path-to-node=&quot;25,2,0&quot; data-index-in-node=&quot;37&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;Inventory&lt;/code&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;table.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;p data-path-to-node=&quot;25,3,0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;&lt;b data-path-to-node=&quot;25,3,0&quot; data-index-in-node=&quot;0&quot; style=&quot;forced-color-adjust: none; box-shadow: none !important;&quot;&gt;Observer&lt;/b&gt;&lt;span&gt;&amp;nbsp;&lt;/span&gt;triggers an alert for users who had &quot;Notify Me&quot; enabled for the product.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="180" width="500" x="590" y="3810" as="geometry" />
        </mxCell>
        <mxCell id="KpuK1pq2YqOiBVYZuBWj-5" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="410" width="804.29" x="850" y="4040" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
